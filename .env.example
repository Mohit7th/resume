# Public canonical URL for the deployed resume site.
# Example: https://mohit7th.github.io/resume
VITE_SITE_URL=https://mohit7th.github.io/resume

# Public path or full URL for the downloadable resume PDF.
VITE_RESUME_PDF_PATH=/assets/Mohit_Uniyal.pdf

# Keep this false for a public static resume site unless you intentionally want
# the admin editor route available.
VITE_ENABLE_ADMIN=false

# Password for the /admin editor. NOTE: this is a static site with no backend,
# so this only hides the editor UI — it is NOT real security. Change it from the
# default before enabling the admin route in production.
VITE_ADMIN_PASSWORD=change-me
